*-----------------------------------------------------
*  Name          : glow_colorset.x2m
*  Author        : Camilla DeSantis and Davide Manzione
*  MODEL TO TEST GLOW COLORSET GEOMETRIES WITH GLOW
*-----------------------------------------------------
*  Define STRUCTURES and MODULES used
*-----------------------------------------------------
SEQ_ASCII TDT_LAT_TISO :: FILE './colorset_s30.dat' ;
SEQ_ASCII TDT_LAT_PS :: FILE './colorset_tiso.eps' ;
SEQ_ASCII TDT_LAT_M :: FILE './colorset_tiso.m' ;
MODULE
    G2S: MAC: SALT: MCCGT: ASM: FLU: EDI: TLM: DELETE: END: ;
LINKED_LIST
    MACRO4G TRACK CP FLUX OUT ;
SEQ_BINARY
    TRACK_f ;
PROCEDURE assertS ;
*----
*  Input Macrolib
*----
