*
*-----------------------------------------------------
*  TISO Tracking of the imported geometry
*-----------------------------------------------------
TDT_LAT_PS := G2S: TDT_LAT_TISO ;
TRACK TRACK_f := SALT: TDT_LAT_TISO ::
    TITL 'glow_colorset imported'
    EDIT 6
    ANIS 1
    TISO 12 20.0
    REND LONG
    ;

TDT_LAT_M := TLM: TRACK TRACK_f ::
    EDIT 99
    NTPO 1
    DIRECTIONS NoPause DIR 0
    ;

TRACK := MCCGT: TRACK TRACK_f ::
  EDIT 1
  LCMD 3 AAC 150 TMT SCR 0 EPSI 1E-5
  MAXI 1 KRYL 0 HDD 0.0 ;

*-----------------------------------------------------
*  Flux calculation
*-----------------------------------------------------
CP := ASM: MACRO4G TRACK TRACK_f :: ARM ;
FLUX := FLU: MACRO4G CP TRACK TRACK_f :: TYPE K ;

*-----------------------------------------------------
*  Editing
*-----------------------------------------------------

OUT := EDI: MACRO4G TRACK FLUX ::
    EDIT 4
    MERG COMP
    COND
    ;

assertS FLUX :: 'K-EFFECTIVE' 1 1.014008 ;
ECHO "test glow_colorset completed" ;
END: ;
QUIT "LIST" .
